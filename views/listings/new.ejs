<% layout ('layouts/boilerplate')-%>
    <h3>New Listing</h3>
    <br>
    <form method="post" action="/listings" novalidate class="needs-validation" enctype="multipart/form-data">
        <div class="row">
            <div class="col-8 offset-2">
        <div class="mb-3">
        <label class="form-label" for="title">Title</label>
        <input name="title" placeholder="Enter title" class="form-control" required>
        <div class="valid-feedback">Title looks good</div>
    </div>

        <br>
        <div class="mb-3">
            <label class="form-label" for="Description">Description</label>
            <textarea name="description" placeholder="Description" class="form-control" required></textarea>
            <div class="invalid-feedback">must be less than 100 characters</div>
        </div>
        
        
        <div class="row">
        <div class="mb-3 col-4">
            <label class="form-label" for="Price">Price</label>
            
            <input name="price" placeholder="Price" type="number" step="0.01" class="form-control" required>
             <div class="invalid-feedback">Enter valid price</div>
        </div>
        
        
        <div class="mb-3 col-8">
             <label class="form-label" for="Location">Location</label>
            <input name="location" placeholder="location" class="form-control" required>
             <div class="invalid-feedback">Enter valid location</div>
        </div>
        </div>
        
        
        <div class="mb-3">
            <label class="form-label" for="Country">Country</label>
            <input name="country" placeholder="country" class="form-control" required>
             <div class="invalid-feedback">Enter valid country</div>
        </div>
        
        <br>

        <div class="mb-3">
            <label class="form-label" for="image">Upload Image</label>
            <input name="image" type="file" class="form-control" required>
             <div class="invalid-feedback">Upload Valid Image</div>
        </div>
        
        <br>
        </div>
        </div>
        <button class="btn btn-dark">Create</button>
        
    </form>