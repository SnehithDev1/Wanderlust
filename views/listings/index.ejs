<% layout ('layouts/boilerplate')-%>
<h3>All Listings</h3><br>

<div class="row row-cols-1 row-cols-md-2 row-cols-lg-3" style="margin-bottom: 5rem;">
     <% for(let listings of allListings){ %>
    <div class="col">
        <a class="listing-link" href="/listings/<%=listings._id%>">
            <div class="card">
                <img src="<%=listings.image.url%>" class="card-img-top" alt="listing-image" style="height: 17rem; object-fit: cover;">
                <div class="card-img-overlay"></div>
                <div class="card-body">
                    <p class="card-text"><b><%=listings.title%></b></p>
                    
                    <p>&#8377 <%= listings.price ? listings.price.toLocaleString("en-IN") : "Price Unavailable" %>/night</p>
                
                </div>
            </div>
        </a>
    </div>
    <% } %>
</div>