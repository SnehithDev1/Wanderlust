<% layout ('layouts/boilerplate')-%>
<div class="row 12 offset-2">
    <div class="col-8">
    <h3>Edit the listing</h3>
    <br>
    <form method="post" action="/listings/<%=listing._id %>?_method=PUT" novalidate class="needs-validation" enctype="multipart/form-data">
    <div>
        <label class="form-label" for="title">Title</label>
        <input name="title" value="<%=listing.title%>" class="form-control" required>
    </div>
        
    <br><br/>
<div>
 <label class="form-label" for="description">Description</label>
 <textarea name="description" cols="45" rows="10"class="form-control" required><%=listing.description%></textarea>
</div>
   
    <br><br/>
    <div>
    <label class="form-label" for="image">Upload Image</label>
    <img src="<%=oriImg%>" >
<input name="image" value="<%= listing.image?.url || '' %>" class="form-control" type="file" >
    </div>
    
    <br><br/>
    <div class="row">
    <div class="mb-3">
         <label class="form-label" for="Location">Location</label>
         <input name="location" value="<%=listing.location%>" class="form-control" required>
    </div>
   
    <br><br/>
        <div class="mb-3 col-4">
         <label class="form-label" for="price">Price</label>
         <input name="price" value="<%=listing.price%>" class="form-control" required>
    </div>
   </div>
   
    <div class="mb-3">
        <label class="form-label" for="Country">Country</label>
<input name="country" value="<%=listing.country%>" class="form-control"required>
    </div>
    
    <br><br/>
    <button class="btn btn-dark">Submit</button>
    </form>
    </div>
    </div>