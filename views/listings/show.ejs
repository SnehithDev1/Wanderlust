<% layout ('layouts/boilerplate')-%>

<div class="listing-show container py-4">
  <div class="listing-hero mb-4">
    <img src="<%= listing.image?.url || '/css/placeholder.jpg' %>" alt="<%= listing.title %>" class="img-fluid w-100 rounded-3 listing-hero-img">
  </div>

  <div class="row">
    <div class="col-lg-8">
      <div class="d-flex justify-content-between align-items-start mb-3">
        <div>
          <h1 class="listing-title mb-1"><%= listing.title %></h1>
          <div class="text-muted listing-meta">
            <span class="me-2"><i class="fa-solid fa-location-dot"></i> <%= listing.location %></span>
            <span><%= listing.country %></span>
          </div>
        </div>
        <div class="listing-price h4 text-dark">₹ <%= listing.price.toLocaleString("en-IN") %></div>
      </div>

      <hr>

      <h5 class="mb-2">About this listing</h5>
      <br>
      <p> <b>Owner: <%=listing.owner.username%></b> </p>
      <p class="lead"><%= listing.description %></p>

      <hr>

      <h6>Amenities</h6>
      <div class="d-flex flex-wrap gap-3 mb-4">
        <span class="badge bg-light text-dark border">Wifi</span>
        <span class="badge bg-light text-dark border">Kitchen</span>
        <span class="badge bg-light text-dark border">Free parking</span>
        <span class="badge bg-light text-dark border">Washing machine</span>
      </div>
    </div>

    <div class="col-lg-4">
      <div class="card booking-card shadow-sm rounded-3 p-3">
        <div class="d-flex justify-content-between align-items-center mb-2">
          <div class="h5 mb-0">₹ <%= listing.price.toLocaleString("en-IN") %></div>
          <div class="text-muted">per stay</div>
        </div>
        <% if(currUser&& currUser._id.equals(listing.owner._id)){%>
        <div class="mt-3 text-center">
          <a href="/listings/<%= listing._id %>/edit" class="btn btn-outline-secondary btn-sm me-2">Edit</a>
          <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE" style="display:inline;">
            <button type="submit" class="btn btn-danger btn-sm">Delete</button>
          </form>
        </div>
        <%}%>
          </div>
        </div>
      </div>
    </div>
    <hr>
    <% if(currUser) { %>
  <div class="mt-4 mb-4">
    <hr>
    <h4>Leave a Review</h4>
    <form method="POST" action="/listings/<%= listing._id %>/review" novalidate class="needs-validation">
      
      <div class="mb-3 mt-3">
        <label for="rating" class="form-label">Rating</label>
        <input type="range" min="1" max="5" id="rating" name="review[rating]" class="form-range" required>
      </div>
      
      <div class="mb-3 mt-3">
        <label for="comment" class="form-label">Comments</label>
        <textarea name="review[comment]" id="comment" cols="30" rows="5" class="form-control" required></textarea>
        <div class="invalid-feedback">Please enter a comment to submit your review.</div>
      </div>
      
      <button class="btn btn-dark">Submit Review</button>
    </form>
  </div>
<% } %>


 <div class="reviews-section mt-4">
    <h5 class="mb-3">Reviews</h5>
    <% if(listing.review && listing.review.length > 0) { %>
      <div class="reviews-container">
        <% for(let review of listing.review) { %>
          <div class="card mb-3 shadow-sm border-0">
            <div class="card-body">
              <div class="d-flex justify-content-between align-items-start mb-2">
                <div>
                  <div class="mb-1">
                    <% for(let i = 0; i < review.rating; i++) { %>
                      <i class="fa-solid fa-star text-warning"></i>
                    <% } %>
                    <span class="ms-2 text-muted small">(<%= review.rating %>/5)</span>
                  </div>
                </div>
               
               <% if(currUser && review.author && currUser._id.equals(review.author._id)) { %>
                <form method="POST" action="/listings/<%= listing._id %>/review/<%= review._id %>?_method=DELETE" style="display:inline;">
                  <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                </form>
               <% } %>

              </div>
              <h6 class="card-title"><%= review.author ? review.author.username : 'Anonymous' %></h6>
              <p class="card-text mb-0"><%= review.comment %></p>
              <small class="text-muted d-block mt-2">
                <% if (review.createdAt) { %>
                  <%= review.createdAt.toLocaleDateString() %>
                <% } %>
              </small>
            </div>
          </div>
        <% } %>
      </div>
    <% } else if(!currUser && listing.review.length==0 ){%>
       <p class="text-muted">No reviews yet. Login to review!</p>
    <%}else { %>
      <p class="text-muted">No reviews yet. Be the first to review!</p>
    <% } %>
  </div>
 
  <div class="col-12 mt-4 mb-4">
    <hr>
    <h5 class="mb-3">Where you'll be</h5>
    
    <div id="map" 
         style="height: 400px; width: 100%; border-radius: 10px; z-index: 1;"
         data-coordinates="<%= JSON.stringify(listing.geometry ? listing.geometry.coordinates : [78.9629, 20.5937]) %>"
         data-title="<%= listing.title %>">
    </div>
</div>

<script>
    // Grab the map element from the DOM
    const mapElement = document.getElementById('map');

    // Extract the data variables from the HTML attributes
    const dbCoordinates = JSON.parse(mapElement.dataset.coordinates);
    const listingTitle = mapElement.dataset.title;

    // MongoDB stores [Longitude, Latitude] -> Leaflet wants [Latitude, Longitude]
    const mapCoordinates = [dbCoordinates[1], dbCoordinates[0]];

    // Initialize the map
    const map = L.map('map').setView(mapCoordinates, 11); 

    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors'
    }).addTo(map);

    // Add the marker
    L.marker(mapCoordinates).addTo(map)
        .bindPopup(`<b>${listingTitle}</b><br>Exact location provided after booking.`)
        .openPopup();
</script>